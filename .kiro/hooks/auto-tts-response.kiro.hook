{
  "enabled": true,
  "name": "Auto Text-to-Speech",
  "description": "Automatically converts agent responses to speech using 80/20 summarization",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Summarize your last response using the 80/20 rule - extract only the core 20% of key points that give 80% of the value. Remove technical details, code explanations, and verbose content. Then convert this concise summary to speech using the text_to_speech MCP tool. Make it natural and easy to listen to."
  }
}